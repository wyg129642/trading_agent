# ============================================================
# Trading Agent — STAGING environment
# ============================================================
#
# Deployment: /home/ygwang/trading_agent_staging   (branch: staging)
# Public URL: http://39.105.42.197:20301
#
# Copy to `.env` inside the STAGING worktree (NOT the prod worktree).
#
# Isolation strategy — every value that would otherwise collide with
# production is auto-scoped in backend/app/config.py when APP_ENV=staging:
#   * PostgreSQL      →  trading_agent_staging  (same server, different DB)
#   * Redis           →  DB index 1             (same server, different logical DB)
#   * Milvus          →  kb_chunks_staging, user_kb_chunks_staging
#   * ClickHouse      →  db_spider_staging      (create it before first run)
#   * Personal KB     →  stg_documents, stg_chunks, stg_fs.files/chunks
#   * Research log    →  stg_research_sessions
#
# The remote crawler Mongo data (8 platforms at 192.168.31.176:35002) is
# READ-ONLY from staging. Crawlers, engine, proactive scanner, and the
# chat-memory processor all refuse to start when APP_ENV=staging — see
# start_web.sh. This is deliberate: double-writing crawlers would burn
# VIP daily quotas (AceCamp) and fight over the same per-platform token.
# ============================================================

# --- Environment identity (CRITICAL: this flag drives all isolation) ---
APP_ENV=staging
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=20301
# Add the staging public endpoint so the browser can hit the backend
# directly from the staging host:port.
CORS_ORIGINS=http://localhost:5173,http://39.105.42.197:20301,http://localhost:20301

# --- Database (same Postgres instance, scoped DB) ---
# POSTGRES_DB is auto-suffixed to trading_agent_staging when APP_ENV=staging,
# so you can leave it as the bare name. Explicit override also works.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_agent
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=changeme_pg_password

# --- Redis (same instance; staging uses logical DB 1) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth (can share prod secrets — tokens are env-independent) ---
JWT_SECRET_KEY=changeme_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider (OK to share — no per-env isolation needed) ---
LLM_PROVIDER=zhipu
LLM_API_KEY=your_zhipu_api_key_here
LLM_PROMPT_LANGUAGE=zh

# --- Feishu Webhook (consider a staging-only channel so flaky alerts
#     don't page the team during experimentation) ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-STAGING-hook

# --- Uqer / DataYes API ---
UQER_TOKEN=your_uqer_token_here

# --- Web search ---
BAIDU_API_KEY=your_baidu_api_key_here
TAVILY_API_KEY=
JINA_API_KEY=

# --- ClickHouse (shared server, create a staging-scoped DB once) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=192.168.31.137
CLICKHOUSE_PORT=38123
CLICKHOUSE_DB=db_spider
CLICKHOUSE_USER=u_spider
CLICKHOUSE_PASSWORD=changeme_ch_password

# --- Market Data ClickHouse (READ-ONLY view — no staging scoping needed) ---
MARKET_CH_HOST=192.168.31.137
MARKET_CH_PORT=38123
MARKET_CH_DB=db_market
MARKET_CH_USER=researcher
MARKET_CH_PASSWORD=researcher

# --- Alpaca / Futu: shared with prod (quote APIs are stateless) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_URL=https://data.alpaca.markets

FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_LOGIN_ACCOUNT=
FUTU_LOGIN_PWD_MD5=

# --- OpenAI / Gemini ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_HTTP_PROXY=

# --- Vector retrieval ---
# Milvus collection auto-suffixes to `kb_chunks_staging`. The ingest
# pipeline is DISABLED on staging (see VECTOR_SYNC_ENABLED below) to
# avoid a duplicate copy of the crawl corpus — kb_search falls back
# to Phase A in-memory BM25 which is good enough for testing.
TEI_BASE_URL=http://116.239.28.36:8080
TEI_MODEL_NAME=qwen3-embed

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=kb_chunks

# Turn OFF background vector sync on staging — prod ingests; staging
# reads. If you specifically want to experiment with the ingest pipeline,
# flip this to true, but expect a 1-day backfill the first time it runs.
VECTOR_SYNC_ENABLED=false
KB_SEARCH_LEGACY=false
EMBEDDING_MODEL_VERSION=qwen3-emb-8b-v1

# --- KB share-with-prod overrides (staging only) ---
# Both default-off in config.py. Enabled here so the AI research assistant
# and workspace page have real data to exercise during testing.
#   KB_SHARE_WITH_PROD=true      → kb_search reads prod Milvus `kb_chunks`
#                                 (read-only; safe)
#   USER_KB_SHARE_WITH_PROD=true → user_kb_search + MyKnowledgeBase workspace
#                                 use prod's documents/chunks/fs.* + Milvus
#                                 user_kb_chunks. Staging uploads/deletes
#                                 WILL HIT PROD DATA — keep this off when
#                                 staging is exposed to external beta users.
KB_SHARE_WITH_PROD=true
USER_KB_SHARE_WITH_PROD=true

# --- Speech-to-text (shared tunnel — staging uses same ASR service) ---
ASR_SERVICE_URL=http://127.0.0.1:8760
