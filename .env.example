# ============================================================
# Trading Agent — Environment Variables
#
# For *new* multi-environment deploys, prefer:
#   .env.production.example  → copy to .env inside the prod worktree
#   .env.staging.example     → copy to .env inside the staging worktree
#
# This legacy template is still a valid single-env starting point
# (all envs unset → defaults in backend/app/config.py). See
# DEPLOYMENT.md for how production / staging are separated.
# ============================================================

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_agent
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=changeme_pg_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_SECRET_KEY=changeme_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ---
LLM_PROVIDER=zhipu
LLM_API_KEY=your_zhipu_api_key_here
LLM_PROMPT_LANGUAGE=zh

# --- Feishu Webhook ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# --- Uqer / DataYes API ---
UQER_TOKEN=your_uqer_token_here

# --- Baidu Search API ---
BAIDU_API_KEY=your_baidu_api_key_here

# --- ClickHouse (optional) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=192.168.31.137
CLICKHOUSE_PORT=38123
CLICKHOUSE_DB=db_spider
CLICKHOUSE_USER=u_spider
CLICKHOUSE_PASSWORD=changeme_ch_password

# --- Market Data ClickHouse (A-share realtime kline, used by stock_quote) ---
MARKET_CH_HOST=192.168.31.137
MARKET_CH_PORT=38123
MARKET_CH_DB=db_market
MARKET_CH_USER=researcher
MARKET_CH_PASSWORD=researcher

# --- Alpaca (US realtime quotes via IEX, free) — fallback when Futu is down ---
# Create a paper account at https://app.alpaca.markets then go to "API Keys"
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Futu OpenAPI (primary source for HK / A-share / US quotes) ---
# Requires running FutuOpenD on the same host. Login account = 牛牛号 or moomoo ID.
# FUTU_LOGIN_PWD_MD5 is the 32-char MD5 hex of the plaintext login password.
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_LOGIN_ACCOUNT=
FUTU_LOGIN_PWD_MD5=

# --- OpenAI (native API for GPT models) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Google Gemini (native API with grounding) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_HTTP_PROXY=

# --- Vector retrieval (Phase B hybrid RAG upgrade) ---
# TEI endpoint on jumpbox (Qwen3-Embedding-8B, 4096-dim).
# TEI_API_KEY is written to .env.secrets by scripts/deploy_jumpbox_tei.sh —
# do NOT commit it here.
TEI_BASE_URL=http://116.239.28.36:8080
TEI_MODEL_NAME=qwen3-embed

# --- Speech-to-text (Qwen3-ASR-1.7B on jumpbox) ---
# The ASR service binds to 127.0.0.1:8760 on the jumpbox; the web server
# reaches it via a supervised SSH tunnel (ops/asr_tunnel/install_tunnel.sh).
# ASR_SERVICE_API_KEY is written to .env.secrets by
# ops/asr_jumpbox/install_asr_jumpbox.sh — do NOT commit it here.
ASR_SERVICE_URL=http://127.0.0.1:8760

# Milvus 2.4 standalone (docker-compose.vector.yml)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=kb_chunks

# Toggles
VECTOR_SYNC_ENABLED=true
KB_SEARCH_LEGACY=false
EMBEDDING_MODEL_VERSION=qwen3-emb-8b-v1

# --- Personal Knowledge Base (user-uploaded documents) ---
# 2026-04-23: migrated from local MongoDB to remote cluster
# 192.168.31.176:35002, DB `ti-user-knowledge-base`. The defaults in
# backend/app/config.py already point to remote; set these only when
# rolling back to a local instance (e.g. for offline dev / tests).
# USER_KB_MONGO_URI=mongodb://u_spider:prod_X5BKVbAc@192.168.31.176:35002/?authSource=admin
# USER_KB_MONGO_DB=ti-user-knowledge-base

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
