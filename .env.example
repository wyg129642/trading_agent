# ============================================================
# Trading Agent — Environment Variables
# Copy this to .env and fill in your actual values
# ============================================================

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_agent
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=changeme_pg_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_SECRET_KEY=changeme_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ---
LLM_PROVIDER=zhipu
LLM_API_KEY=your_zhipu_api_key_here
LLM_PROMPT_LANGUAGE=zh

# --- Feishu Webhook ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# --- Uqer / DataYes API ---
UQER_TOKEN=your_uqer_token_here

# --- Baidu Search API ---
BAIDU_API_KEY=your_baidu_api_key_here

# --- ClickHouse (optional) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=192.168.31.137
CLICKHOUSE_PORT=38123
CLICKHOUSE_DB=db_spider
CLICKHOUSE_USER=u_spider
CLICKHOUSE_PASSWORD=changeme_ch_password

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
