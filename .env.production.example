# ============================================================
# Trading Agent — PRODUCTION environment
# ============================================================
#
# Deployment: /home/ygwang/trading_agent   (branch: main)
# Public URL: old domain (legacy :8000)
#
# Copy to `.env` inside the production worktree. Never edit `.env`
# directly on the server — keep .env.production (checked into your
# private config store) as the source of truth and rsync from there
# when deploying.
#
# This file differs from .env.staging ONLY in APP_ENV, APP_PORT,
# and CORS_ORIGINS. Every other credential / API key should be
# identical so the two deployments are truly "same code on two
# envs" — the whole point of having staging in the first place.
# ============================================================

# --- Environment identity (DO NOT change) ---
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (local docker, shared Postgres instance) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_agent
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=changeme_pg_password

# --- Redis (same instance as staging; prod uses logical DB 0) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_SECRET_KEY=changeme_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ---
LLM_PROVIDER=zhipu
LLM_API_KEY=your_zhipu_api_key_here
LLM_PROMPT_LANGUAGE=zh

# --- Feishu Webhook ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# --- Uqer / DataYes API ---
UQER_TOKEN=your_uqer_token_here

# --- Web search ---
BAIDU_API_KEY=your_baidu_api_key_here
TAVILY_API_KEY=
JINA_API_KEY=

# --- ClickHouse (optional) ---
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=192.168.31.137
CLICKHOUSE_PORT=38123
CLICKHOUSE_DB=db_spider
CLICKHOUSE_USER=u_spider
CLICKHOUSE_PASSWORD=changeme_ch_password

# --- Market Data ClickHouse (A-share realtime kline) ---
MARKET_CH_HOST=192.168.31.137
MARKET_CH_PORT=38123
MARKET_CH_DB=db_market
MARKET_CH_USER=researcher
MARKET_CH_PASSWORD=researcher

# --- Alpaca (US realtime fallback, free IEX) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Futu OpenAPI (primary quotes) ---
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_LOGIN_ACCOUNT=
FUTU_LOGIN_PWD_MD5=

# --- OpenAI / Gemini ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_HTTP_PROXY=

# --- Vector retrieval ---
# Collection name is auto-suffixed with _staging when APP_ENV=staging,
# so leave the bare name here — prod sees `kb_chunks`, staging sees
# `kb_chunks_staging` automatically.
TEI_BASE_URL=http://116.239.28.36:8080
TEI_MODEL_NAME=qwen3-embed

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=kb_chunks

VECTOR_SYNC_ENABLED=true
KB_SEARCH_LEGACY=false
EMBEDDING_MODEL_VERSION=qwen3-emb-8b-v1

# --- Speech-to-text (shared tunnel) ---
ASR_SERVICE_URL=http://127.0.0.1:8760
