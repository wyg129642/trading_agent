{
  "name": "光通信公司收入拆分 (标准版)",
  "slug": "optical_standard_v1",
  "industry": "optical_modules",
  "version": 1,
  "description": "从业绩会 + 专家访谈 → 业务部门拆分 → 量×价 → margin 级联 → EPS/PE。适用于 LITE / COHR 等模块+芯片全栈公司。",
  "nodes": [
    {
      "id": "step_1",
      "type": "GATHER_CONTEXT",
      "label": "读业绩会 & 基本面",
      "config": {
        "lookback_days": 180,
        "tools": ["kb_search", "alphapai_recall", "jinmen_search"],
        "doc_types": ["earnings_call", "investor_day", "10-K", "10-Q"]
      },
      "next_on_success": "step_2",
      "next_on_fail": "fail"
    },
    {
      "id": "step_2",
      "type": "DECOMPOSE_SEGMENTS",
      "label": "拆分业务部门",
      "config": {
        "skeleton_source": "segments_schema.yaml",
        "allow_custom_segments": true,
        "prompt_template": "分析 {ticker} ({company_name}) 当前实际披露的业务部门。以行业标准骨架 ({skeleton}) 为参考，但允许公司特殊拆分。输出结构化 JSON 列表，每项含 slug/label_zh/volume_unit/asp_unit。"
      },
      "next_on_success": "step_3"
    },
    {
      "id": "step_3",
      "type": "CLASSIFY_GROWTH_PROFILE",
      "label": "归类每个业务部门的增长曲线",
      "config": {
        "profiles": ["stable", "declining", "high_growth", "new"],
        "tools": ["kb_search", "alphapai_recall"]
      },
      "next_on_success": "step_4"
    },
    {
      "id": "step_4",
      "type": "EXTRACT_HISTORICAL",
      "label": "提取近 3 年各业务收入历史值",
      "config": {
        "years_back": 3,
        "require_sources": ["10-K", "10-Q"],
        "tools": ["kb_search", "alphapai_recall"]
      },
      "next_on_success": "step_5a"
    },
    {
      "id": "step_5a",
      "type": "MODEL_VOLUME_PRICE",
      "label": "高成长业务: 量×价拆分",
      "config": {
        "applies_to_profiles": ["high_growth", "new"],
        "min_expert_sources": 2,
        "cross_check_external_growth": true,
        "tools": ["alphapai_recall", "jinmen_search", "kb_search"],
        "prompt_template": "针对 {ticker} 的 {segment} ({periods}): (1) 从业绩会/10-K查是否有量价分拆; (2) 用 jinmen/alphapai 拉 ≥2 位专家口径; (3) 分别给 volume / ASP 值，保留多组并行口径到 alternative_values; (4) 若为AI相关，与 NVDA/GOOG 发货节奏做 sanity."
      },
      "next_on_success": "step_6"
    },
    {
      "id": "step_5b",
      "type": "APPLY_GUIDANCE",
      "label": "稳定业务: 套管理层指引或 3-5% 缺省",
      "config": {
        "applies_to_profiles": ["stable", "declining"],
        "default_growth_rate": 0.03,
        "negative_default": -0.02
      },
      "next_on_success": "step_6"
    },
    {
      "id": "step_6",
      "type": "MARGIN_CASCADE",
      "label": "Margin → NI → EPS → PE 级联",
      "config": {
        "strategy": "guidance_first",
        "fallback": "peer_comp",
        "tax_rate_source": "guidance_or_default",
        "use_price_volume_driver_adjust": true
      },
      "next_on_success": "step_7"
    },
    {
      "id": "step_7",
      "type": "VERIFY_AND_ASK",
      "label": "CoVe 核验 + 低置信度打 flag",
      "config": {
        "verifier_model": "google/gemini-3.1-pro-preview",
        "debate_on_critical_cells": true,
        "tiebreaker_model": "openai/gpt-5.4",
        "diff_threshold_pct": 0.10,
        "critical_cell_patterns": [
          "segment.*.rev.*",
          "total_revenue.*",
          "ni.*",
          "eps.*",
          "pe.*"
        ]
      },
      "next_on_success": "done"
    }
  ],
  "edges": [
    {"from": "step_1", "to": "step_2"},
    {"from": "step_2", "to": "step_3"},
    {"from": "step_3", "to": "step_4"},
    {"from": "step_4", "to": "step_5a"},
    {"from": "step_4", "to": "step_5b"},
    {"from": "step_5a", "to": "step_6"},
    {"from": "step_5b", "to": "step_6"},
    {"from": "step_6", "to": "step_7"}
  ]
}
